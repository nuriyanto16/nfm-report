# Salin menjadi .env di root project pada VPS (di samping docker-compose.prod.yml).
APP_USER=admin
APP_PASS=ganti-dengan-password-kuat
APP_SECRET=ganti-dengan-secret-acak-panjang
TOKEN_TTL_HOURS=12
CACHE_TTL_SECONDS=300

# Port host (hanya di-bind ke 127.0.0.1). Ubah bila bentrok di VPS.
API_PORT=8077
WEB_PORT=3077
