# Salin ke .env dan sesuaikan.

# Basic auth (kosongkan keduanya untuk menonaktifkan auth saat dev).
BASIC_AUTH_USER=admin
BASIC_AUTH_PASS=ubah-password-ini

# TTL cache data spreadsheet (detik).
CACHE_TTL_SECONDS=300

# Origin frontend yang diizinkan (pisahkan dengan koma).
CORS_ORIGINS=http://localhost:3000

# Path biner LibreOffice untuk export PDF (opsional bila sudah di PATH).
# Windows contoh:
# SOFFICE_BIN=C:\Program Files\LibreOffice\program\soffice.exe
